COLS.forEach(c=>visibleCols[c.key]=true);

// ══════════════════════════════════════════════════════════
// COL PANEL
// ══════════════════════════════════════════════════════════
function buildColPanel(){
  document.getElementById('colChecks').innerHTML=COLS.map(c=>`
    <label class="col-check ${visibleCols[c.key]?'checked':''}" id="lbl-${c.key}">
      <input type="checkbox" ${visibleCols[c.key]?'checked':''} onchange="toggleCol('${c.key}',this.checked)">
      ${c.label}
    </label>`).join('');
}
function toggleCol(key,checked){visibleCols[key]=checked;document.getElementById('lbl-'+key).classList.toggle('checked',checked);renderTable()}
function setAllCols(val){COLS.forEach(c=>{visibleCols[c.key]=val});buildColPanel();renderTable()}
function toggleColPanel(){
  document.getElementById('colPanel').classList.toggle('open');
  document.getElementById('colBtn').classList.toggle('open');
}
document.addEventListener('click',e=>{
  const p=document.getElementById('colPanel'),b=document.getElementById('colBtn');
  if(!p.contains(e.target)&&e.target!==b){p.classList.remove('open');b.classList.remove('open')}
});

// ══════════════════════════════════════════════════════════
// REGION TOGGLES
// ══════════════════════════════════════════════════════════
function toggleRegion(r){
  activeRegions[r]=!activeRegions[r];
  document.querySelector(`.rtog[data-r="${r}"]`).classList.toggle('active',activeRegions[r]);
  renderTable();
}

// ══════════════════════════════════════════════════════════
// SORT
// ══════════════════════════════════════════════════════════
function quickSort(btn,key){
  document.querySelectorAll('.sbtn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  if(sortKey===key){sortDir=sortDir==='desc'?'asc':'desc'}
  else{sortKey=key;sortDir=(COLS.find(c=>c.key===key)||{}).dir||'desc'}
  renderTable();
}
function sortByCol(key){
  if(sortKey===key){sortDir=sortDir==='desc'?'asc':'desc'}
  else{sortKey=key;sortDir=(COLS.find(c=>c.key===key)||{}).dir||'desc'}
  renderTable();
}

// ══════════════════════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════════════════════
function fmt(n,d=0){return n.toLocaleString('fr-FR',{maximumFractionDigits:d})}
function fmtGDP(v){return v>=1000?(v/1000).toFixed(2)+' T':fmt(v,0)+' G'}
function giniCls(v){return v<0.29?'gini-lo':v<0.38?'gini-md':'gini-hi'}
function lifeCls(v){return v>=82?'life-hi':v>=78?'life-md':'life-lo'}
function hdiCls(v) {return v>=0.92?'hdi-hi': v>=0.86?'hdi-md':'hdi-lo'}
function getMax(d,k){return Math.max(...d.map(x=>x[k]))||1}
function getMin(d,k){return Math.min(...d.map(x=>x[k]))}
function colorVal(val,min,max,inverse){
  const r=(val-min)/(max-min);
  const g=inverse?r:1-r;
  return g<0.33?'var(--rose)':g<0.66?'var(--amber)':'var(--green)';
}

// ══════════════════════════════════════════════════════════
// RENDER STATS
// ══════════════════════════════════════════════════════════
function renderStats(data){
  const n=data.length;
  if(!n){document.getElementById('statsStrip').innerHTML='';return}
  const totalGdp=data.reduce((s,d)=>s+d.gdp,0);
  const avgGdppc=data.reduce((s,d)=>s+d.gdppc,0)/n;
  const avgGini=data.reduce((s,d)=>s+d.gini,0)/n;
  const avgLife=data.reduce((s,d)=>s+d.life,0)/n;
  const avgHdi=data.reduce((s,d)=>s+d.hdi,0)/n;
  const bestGini=data.reduce((p,c)=>p.gini<c.gini?p:c);
  const bestLife=data.reduce((p,c)=>p.life>c.life?p:c);
  document.getElementById('totalCount')&&(document.getElementById('totalCount').textContent=n+' régions');
  document.getElementById('statsStrip').innerHTML=`
    <div class="sc"><div class="sc-label">PIB Cumulé</div><div class="sc-val">${fmtGDP(totalGdp)}</div><div class="sc-sub">$Int'l PPA</div></div>
    <div class="sc"><div class="sc-label">PIB/Hab. Moyen</div><div class="sc-val">${fmt(Math.round(avgGdppc/1000))}k</div><div class="sc-sub">$Int'l PPA/an</div></div>
    <div class="sc"><div class="sc-label">Gini Moyen</div><div class="sc-val">${avgGini.toFixed(3)}</div><div class="sc-sub">inégalités revenus</div></div>
    <div class="sc"><div class="sc-label">Meilleur Gini</div><div class="sc-val">${bestGini.gini.toFixed(3)}</div><div class="sc-sub">${bestGini.n}</div></div>
    <div class="sc"><div class="sc-label">Espér. Vie Moy.</div><div class="sc-val">${avgLife.toFixed(1)}</div><div class="sc-sub">années</div></div>
    <div class="sc"><div class="sc-label">+ Longue Vie</div><div class="sc-val">${bestLife.life.toFixed(1)}</div><div class="sc-sub">${bestLife.n}</div></div>
    <div class="sc"><div class="sc-label">IDH Moyen</div><div class="sc-val">${avgHdi.toFixed(3)}</div><div class="sc-sub">PNUD</div></div>
    <div class="sc"><div class="sc-label">Régions</div><div class="sc-val">${n}</div><div class="sc-sub">classées</div></div>`;
}

// ══════════════════════════════════════════════════════════
// RENDER TABLE
// ══════════════════════════════════════════════════════════
function renderTable(){
  const search=document.getElementById('searchInput').value.toLowerCase().trim();
  let data=DATA.filter(d=>{
    if(!activeRegions[d.r])return false;
    if(search)return d.n.toLowerCase().includes(search)||d.a.toLowerCase().includes(search);
    return true;
  });
  data.sort((a,b)=>{
    const asc=sortDir==='asc';
    return asc?a[sortKey]-b[sortKey]:b[sortKey]-a[sortKey];
  });
  renderStats(data);
  const aCols=COLS.filter(c=>visibleCols[c.key]);
  const maxMap={},minMap={};
  aCols.forEach(c=>{maxMap[c.key]=getMax(data,c.key);minMap[c.key]=getMin(data,c.key)});

  // THEAD
  document.getElementById('theadRow').innerHTML=`
    <th>#</th>
    <th>Région</th>
    ${aCols.map(c=>`
      <th id="th-${c.key}" class="${sortKey===c.key?'sorted':''}" onclick="sortByCol('${c.key}')" data-tip="${c.sub}">
        ${c.label}<span class="si">${sortKey===c.key?(sortDir==='desc'?'↓':'↑'):'↕'}</span>
      </th>`).join('')}`;

  // TBODY
  const tbody=document.getElementById('tbody');
  if(!data.length){tbody.innerHTML=`<tr><td colspan="${aCols.length+2}" class="no-results">Aucun résultat</td></tr>`;return}

  tbody.innerHTML=data.map((d,i)=>{
    const cells=aCols.map(c=>{
      const val=d[c.key],max=maxMap[c.key],min=minMap[c.key];
      const barPct=max===min?50:((val-min)/(max-min)*100).toFixed(1);
      const isInverse=c.dir==='asc';
      let content='';
      if(c.key==='gini')   content=`<span class="badge ${giniCls(val)}">${val.toFixed(3)}</span>`;
      else if(c.key==='life') content=`<span class="badge ${lifeCls(val)}">${val.toFixed(1)} ans</span>`;
      else if(c.key==='hdi')  content=`<span class="badge ${hdiCls(val)}">${val.toFixed(3)}</span>`;
      else if(c.key==='gdp')  content=`<div class="vn">${fmtGDP(val)}</div><div class="vs">$Int'l</div>`;
      else if(['gdppc','median','health'].includes(c.key)) content=`<div class="vn">${fmt(val)} $</div><div class="vs">PPA/an</div>`;
      else if(['poverty','unemp','top10'].includes(c.key)){
        const cl=colorVal(val,min,max,false);
        content=`<div class="vn" style="color:${cl}">${val.toFixed(1)} %</div>`;
      } else if(c.key==='homicide'){
        const cl=colorVal(val,min,max,false);
        content=`<div class="vn" style="color:${cl}">${val.toFixed(1)}</div><div class="vs">/100k</div>`;
      } else if(c.key==='co2'){
        const cl=colorVal(val,min,max,false);
        content=`<div class="vn" style="color:${cl}">${val.toFixed(1)}</div><div class="vs">t/an</div>`;
      } else if(['mob','edu'].includes(c.key)){
        const cl=colorVal(val,min,max,true);
        content=`<div class="vn" style="color:${cl}">${fmt(val)}</div>`;
      } else content=`<div class="vn">${fmt(val,1)}</div>`;

      const barColor=isInverse
        ?(barPct>66?'var(--rose)':barPct>33?'var(--amber)':'var(--green)')
        :(barPct>66?'var(--green)':barPct>33?'var(--amber)':'var(--rose)');
      return `<td class="dc">${content}<div class="bt"><div class="bf" style="width:${barPct}%;background:${c.color}30;border-top:1px solid ${c.color}55"></div></div></td>`;
    }).join('');

    const rkStyle=i===0?'color:var(--gold);font-size:17px':i===1?'color:#a0b4c8;font-size:15px':i===2?'color:#8a7060':'';
    return `<tr>
      <td class="rk" style="${rkStyle}">${i+1}</td>
      <td>
        <div class="nc">
          <span class="flag">${d.f}</span>
          <div>
            <div class="n1">${d.n}</div>
            <div class="n2">${d.a} · ${fmt(d.pop)} hab.</div>
          </div>
          <div class="rdot rdot-${d.r}"></div>
        </div>
      </td>
      ${cells}
    </tr>`;
  }).join('');
}

buildColPanel();
renderTable();
</script>
